<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    <key>CFBundleExecutable</key>
    <string>@OFX_EXECUTABLE_NAME@</string>
    <!-- Must match kPluginIdentifier (PLUGIN_OFX_IDENTIFIER in version_gen.h) or DaVinci Resolve / OFX can skip the bundle. -->
    <key>CFBundleIdentifier</key>
    <string>@PLUGIN_OFX_IDENTIFIER@</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>LSP - Simple LUT Generator</string>
    <key>CFBundlePackageType</key>
    <string>BNDL</string>
    <key>CFBundleShortVersionString</key>
    <string>@PLUGIN_DISPLAY_VERSION@</string>
    <key>CFBundleVersion</key>
    <string>@PLUGIN_NUMERIC_VERSION@</string>
    <key>NSPrincipalClass</key>
    <string></string>
</dict>
</plist>
